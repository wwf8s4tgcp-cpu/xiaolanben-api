DB_USER=postgres
DB_PASSWORD=你的Supabase数据库密码
DB_NAME=postgres
DB_PORT=5432
DB_SSL=true

# Supabase 客户端配置
SUPABASE_URL=https://vwf8s4tgcp-cpu.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImppbGZ2eXNwZGdhc3ZwenZudHljIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA3MTQ3NDMsImV4cCI6MjA5NjI5MDc0M30.awFcIfYcbwi-pDR7qFUlcQjIx68Ay0TJjkRU17S-XVQ

